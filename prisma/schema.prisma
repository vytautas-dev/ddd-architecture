generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model EventStore {
  id         String   @id @default(uuid())
  streamId   String
  streamType String
  eventType  String
  payload    Json
  version    Int
  occurredAt DateTime @default(now())

  @@unique([streamId, version])
  @@index([streamId])
  @@map("event_store")
}

model ActiveAuctionView {
  id             String   @id
  sellerId       String
  title          String
  status         String
  currentBid     Float?
  currency       String
  startsAt       DateTime
  endsAt         DateTime
  totalBids      Int      @default(0)
  updatedAt      DateTime @updatedAt

  @@map("active_auctions_view")
}
